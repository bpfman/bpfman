guard d <- tempdir poll-let-bind-helper
defer exec rm -rf $d.path
let marker = "${d.path}/marker"

def await_marker(path) {
  let rc <- exec test -f $path
  if not $rc.ok { exec touch $path }
  retry "waiting from let-bind helper" unless $rc.ok
  print let-bind-ready
}

poll timeout 100ms every 1ms {
  let _ <- await_marker $marker
}

assert path-exists $marker
print after
