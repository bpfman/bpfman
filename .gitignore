# --------------------------------------------------------------------
# Rust implementation.
# https://raw.github.com/github/gitignore/master/Rust.gitignore
# --------------------------------------------------------------------

# Generated by Cargo
# will have compiled files and executables. Anchored to the root:
# the unanchored form also matches directories named debug inside
# the committed Go vendor tree.
/debug/
target/
**/target

# These are backup files generated by rustfmt
**/*.rs.bk

# docs
.venv

# certs
certs

# misc
.idea/
.vscode/launch.json
.vagrant
tests/_tmp
.history
.DS_Store

# Ignore compiled C files
.output

# Ignore docs
site/

# BPF dispatcher build artefacts
bpfman/bpf/*.o
bpfman/bpf/*.d

# RPM build artifacts
*.tar.gz
*.rpm
results_*/
*x86_64/
cargo-vendor-filterer

# --------------------------------------------------------------------
# Go implementation.
#
# The root module's Go dependencies are committed under /vendor, so
# unlike the Rust tooling no blanket vendor ignore appears here.
# --------------------------------------------------------------------
/bin/
.direnv/
.bpf-build-stamp
# BPF objects and dependency files at any depth. Matches both
# the scoped build trees (e2e/testdata/bpf, platform/ebpf,
# dispatcher) and any future subtree, so a stray .bpf.o cannot
# slip into the index when a new test directory is added.
*.bpf.o
*.bpf.d

# Go test binaries left behind by `go test -c` or sandboxed
# test runners. Matches anywhere in the tree; the bin/ outputs
# are already covered by /bin/ above.
*.test

# Kernel module build outputs for e2e/kmod.
/e2e/kmod/.kbuild/
/e2e/kmod/*.ko
/e2e/kmod/*.o
/e2e/kmod/*.mod
/e2e/kmod/*.mod.c
/e2e/kmod/.*.cmd
/e2e/kmod/Module.symvers
/e2e/kmod/modules.order
/e2e/kmod/.kmod-kernel-stamp

/ci-e2e-bundle/
.cache/

# Go build cache persisted across hack/fedora-vm.sh runs.
/.gocache/
