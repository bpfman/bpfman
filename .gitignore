/bin/
bpfman/testdata/
bpfman/internal/server/pb/
archive/bpfman-kernel/bpfman-kernel
.direnv/
.bpf-build-stamp
# BPF objects and dependency files at any depth. Matches both
# the scoped build trees (e2e/testdata/bpf, platform/ebpf,
# dispatcher) and any future subtree, so a stray .bpf.o cannot
# slip into the index when a new test directory is added.
*.bpf.o
*.bpf.d

# Go test binaries left behind by `go test -c` or sandboxed
# test runners. Matches anywhere in the tree; the bin/ outputs
# are already covered by /bin/ above.
*.test

# Kernel module build outputs for e2e/kmod.
/e2e/kmod/.kbuild/
/e2e/kmod/*.ko
/e2e/kmod/*.o
/e2e/kmod/*.mod
/e2e/kmod/*.mod.c
/e2e/kmod/.*.cmd
/e2e/kmod/Module.symvers
/e2e/kmod/modules.order
/e2e/kmod/.kmod-kernel-stamp

/ci-e2e-bundle/
.cache/
