#use flake .#static
use flake
PATH_add $PWD/bin

# Default the bpfman image pullspec for the daily local loop.
# Local-only dev images (build-image-dev, build-image-amd64, etc.)
# never leave this host, so they live in the docker.io/library
# namespace under a plain `bpfman:latest` rather than the canonical
# quay.io/bpfman/bpfman:latest the Makefile defaults to. Push targets
# always set BPFMAN_IMG explicitly, so this default cannot
# accidentally redirect a publish.
export BPFMAN_IMG="${BPFMAN_IMG:-docker.io/library/bpfman:latest}"
